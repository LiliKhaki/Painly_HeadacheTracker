<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HeadacheTracker.Maui.ViewModels"
             xmlns:converters="clr-namespace:HeadacheTracker.Maui.Converters"
             xmlns:local="clr-namespace:HeadacheTracker.Maui.Resources.Strings"
             xmlns:models="clr-namespace:HeadacheTracker.Maui.Models"
             x:DataType="vm:CalendarViewModel" 
    x:Class="HeadacheTracker.Maui.MainPage"
             BackgroundColor="{AppThemeBinding Light={DynamicResource BackgroundLight}, Dark={DynamicResource BackgroundDark}}" 
             Padding="0"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Конвертеры -->
            <converters:CalendarStrokeConverter x:Key="CalendarStrokeConverter"/>
            <converters:CalendarBackgroundConverter x:Key="CalendarBackgroundConverter"/>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
            <converters:NullableDoubleToBoolConverter x:Key="NullableDoubleToBoolConverter"/>
            <converters:IsEndOfRowConverter x:Key="IsEndOfRowConverter"/>
            <converters:ObjectEqualsMultiConverter x:Key="ObjectEqualsMultiConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="10"
               BackgroundColor="{AppThemeBinding Light={DynamicResource BackgroundLight}, Dark={DynamicResource BackgroundDark}}">

            <!-- Кнопка статистики -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="{x:Static local:AppResources.Statistics}"
                        FontSize="16"
                        Command="{Binding OpenStatisticsCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Grid.Column="0"/>
                <Button Text="{x:Static local:AppResources.About}"
                        FontSize="16"
                        Command="{Binding OpenAboutCommand}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Grid.Column="1"/>
            </Grid>

            <!-- Навигация по месяцам -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,0,0,10">
                <Button Text="◀" Command="{Binding PreviousMonthCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"/>
                <Label Text="{Binding CurrentMonthName}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Style="{DynamicResource MonthHeaderTextStyle}"/>
                <Button Text="▶" Command="{Binding NextMonthCommand}"
                        Style="{DynamicResource SecondaryButtonStyle}"/>
            </HorizontalStackLayout>

            <!-- Дни недели -->
            <Grid ColumnDefinitions="*,*,*,*,*,*,*" Padding="0,4,0,2" >
                <Label Text="{x:Static local:AppResources.MondayShort}" HorizontalOptions="Center" FontAttributes="Bold" Style="{DynamicResource SecondaryTextStyle}" />
                <Label Text="{x:Static local:AppResources.TuesdayShort}" Grid.Column="1" HorizontalOptions="Center" FontAttributes="Bold" Style="{DynamicResource SecondaryTextStyle}" />
                <Label Text="{x:Static local:AppResources.WednesdayShort}" Grid.Column="2" HorizontalOptions="Center" FontAttributes="Bold" Style="{DynamicResource SecondaryTextStyle}" />
                <Label Text="{x:Static local:AppResources.ThursdayShort}" Grid.Column="3" HorizontalOptions="Center" FontAttributes="Bold"  Style="{DynamicResource SecondaryTextStyle}" />
                <Label Text="{x:Static local:AppResources.FridayShort}" Grid.Column="4" HorizontalOptions="Center" FontAttributes="Bold" Style="{DynamicResource SecondaryTextStyle}" />
                <Label Text="{x:Static local:AppResources.SaturdayShort}" Grid.Column="5" HorizontalOptions="Center" TextColor="Gray"/>
                <Label Text="{x:Static local:AppResources.SundayShort}" Grid.Column="6" HorizontalOptions="Center" TextColor="Gray"/>
            </Grid>

            <!-- Календарь -->
            <CollectionView ItemsSource="{Binding Days}" SelectionMode="None" SelectedItem="{Binding SelectedDay}">

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="7" />
                </CollectionView.ItemsLayout>

                <!-- DataTemplate для элементов календаря -->
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CalendarDay">
                        <!-- Тип элемента коллекции -->
                        <Grid BackgroundColor="{AppThemeBinding Light=#E6ECE5, Dark=#304030}">
                            <Border Padding="4" Margin="1"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="2">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.SetSelectedDayCommand}"
                                        CommandParameter="{Binding}" />
                                </Border.GestureRecognizers>
                                <Border.Background>
                                    <MultiBinding Converter="{StaticResource CalendarBackgroundConverter}">
                                        <Binding Path="HasEntry" />
                                        <Binding Path="IsToday" />
                                        <Binding Path="IsSelected" />
                                    </MultiBinding>
                                </Border.Background>
                                <Border.Stroke>
                                    <MultiBinding Converter="{StaticResource CalendarStrokeConverter}">
                                        <Binding Path="HasEntry" />
                                        <Binding Path="IsToday" />
                                        <Binding Path="IsSelected" />
                                    </MultiBinding>
                                </Border.Stroke>

                                <Grid>
                                    <Label Text="{Binding Date.Day}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Style="{DynamicResource PrimaryTextStyle}"
                                           Opacity="{Binding IsFromCurrentMonth, Converter={StaticResource BoolToOpacityConverter}}"/>
                                    <BoxView HeightRequest="1" BackgroundColor="#D0D8D3"
                                             VerticalOptions="End" HorizontalOptions="Fill"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

            <!-- CollectionView для записей головной боли -->
            <Grid Style="{DynamicResource PanelStyle}" ColumnDefinitions="2*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="{x:Static local:AppResources.SavedRecords}"
                       Style="{DynamicResource SectionHeaderTextStyle}" />

                <CollectionView Grid.Row="1" Grid.Column="0"
                                ItemsSource="{Binding HeadacheEntriesForSelectedDay}"
                                HeightRequest="200"
                                SelectionMode="None"
                                SelectedItem="{Binding SelectedHeadacheEntry, Mode=TwoWay}">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:HeadacheEntryViewModel">
                            <!-- Тип элемента записи -->
                            <Border Margin="0,2,2,2" Padding="6"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Style="{DynamicResource SurfaceStyle}">

                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding IsSelected}"
                                                 Value="True">
                                        <Setter Property="Stroke"
                                                Value="{AppThemeBinding Light={DynamicResource LightPrimaryColor}, Dark={DynamicResource DarkPrimaryColor}}" />
                                        <Setter Property="StrokeThickness" Value="2"/>
                                        <Setter Property="BackgroundColor"
                                                Value="{AppThemeBinding Light=#E8F5E9, Dark=#1B2A21}" />
                                    </DataTrigger>
                                </Border.Triggers>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.SelectHeadacheEntryCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <VerticalStackLayout>
                                    <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy}'}" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={DynamicResource LightTextPrimaryColor }, Dark={DynamicResource DarkTextPrimaryColor}}"/>
                                    <Label Text="{Binding Intensity, StringFormat='Intensity: {0}'}"
                                           TextColor="{AppThemeBinding Light={DynamicResource LightTextPrimaryColor }, Dark={DynamicResource DarkTextPrimaryColor}}"/>
                                    <Label Text="{Binding Notes}" 
                                           IsVisible="{Binding Notes, Converter={StaticResource StringToBoolConverter}}"
                                           TextColor="{AppThemeBinding Light={DynamicResource LightTextPrimaryColor }, Dark={DynamicResource DarkTextPrimaryColor}}"/>

                                    <!-- CollectionView для медикаментов -->
                                    <CollectionView ItemsSource="{Binding Medications}" SelectionMode="None">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:MedicationInput">
                                                <!-- Тип элемента медикамента -->
                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="{Binding Name}" FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={DynamicResource LightTextPrimaryColor }, Dark={DynamicResource DarkTextPrimaryColor}}"/>
                                                    <Label Text="{Binding Dose, StringFormat='{0} mg'}"
                                                           TextColor="{AppThemeBinding Light={DynamicResource LightTextPrimaryColor }, Dark={DynamicResource DarkTextPrimaryColor}}"/>
                                                </HorizontalStackLayout>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Кнопки справа -->
                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="10" Margin="0,2,2,2" HorizontalOptions="Center" VerticalOptions="Start">
                    <Button Text="{x:Static local:AppResources.AddRecord}" Command="{Binding AddRecordCommand}" WidthRequest="120"
                            Style="{DynamicResource PrimaryButtonStyle}" />
                    <Button Text="{x:Static local:AppResources.EditRecord}" Command="{Binding EditRecordCommand}" WidthRequest="120"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                    <Button Text="{x:Static local:AppResources.DeleteRecord}" Command="{Binding DeleteRecordCommand}" WidthRequest="120"
                            Style="{DynamicResource SecondaryButtonStyle}" />
                </VerticalStackLayout>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>