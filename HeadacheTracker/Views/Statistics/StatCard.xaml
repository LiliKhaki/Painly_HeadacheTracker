<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="HeadacheTracker.Maui.Views.Statistics.StatCard">

    <Border
        Stroke="#888"
        StrokeThickness="1"
        StrokeShape="RoundRectangle 12"
        Padding="12"
        BackgroundColor="{AppThemeBinding Light='#F2F2F2', Dark='#333'}"
        Margin="5">
        <VerticalStackLayout Spacing="4">
            <Label Text="{Binding Title}" FontSize="14" Opacity="0.7" />
            <Label Text="{Binding Value}" FontSize="24" FontAttributes="Bold"/>
        </VerticalStackLayout>
    </Border>
</ContentView>
